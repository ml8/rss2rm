PROJECT_ID=your-project-name
REGION=us-central1         # for example
CLUSTER_NAME=rss2rm
CLUSTER_ZONE=              # Set for zonal clusters (e.g. us-west1-a). Leave empty for regional.
STATIC_IP_NAME=rss2rm-ip
DOMAIN=rss2rm.example.com  # Replace with your actual domain
SQL_INSTANCE_NAME=rss2rm-db
SQL_DB_NAME=rss2rm
SQL_USER=rss2rm
IMAGE_NAME=${REGION}-docker.pkg.dev/${PROJECT_ID}/rss2rm/rss2rm
